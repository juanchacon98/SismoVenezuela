PORT=8080
DATABASE_URL=postgres://app_user:password@localhost:5432/emergencia_ccs

# Optional: authorized JSON/API export for missing-person sync.
# The public API behind desaparecidosterremotovenezuela.com requires reCAPTCHA,
# so configure this only with a permitted export/API endpoint.
MISSING_PERSONS_SOURCE_NAME=desaparecidosterremotovenezuela.com
MISSING_PERSONS_SYNC_URL=
MISSING_PERSONS_SYNC_INTERVAL_MS=600000
MISSING_PERSONS_SYNC_PAGE_SIZE=100
MISSING_PERSONS_SYNC_MAX_RECORDS=500
MISSING_PERSONS_SYNC_TOKEN=
MISSING_PERSONS_SYNC_API_KEY=

# Optional Gemini sync.
GEMINI_API_KEY=
